# SupChainMate API Keys — copy to .env and fill in your values
# All keys are optional — features degrade gracefully without them

# Groq (primary AI copilot — LLaMA-3.3-70B, sub-second inference)
# Get your key: https://console.groq.com/keys
GROQ_API_KEY=your_groq_key_here

# NVIDIA cuOpt (real vehicle route optimisation via NIM)
# Get your key: https://build.nvidia.com
NVIDIA_CUOPT_API_KEY=your_nvidia_cuopt_key_here

# NVIDIA LLaMA (legacy fallback copilot)
NVIDIA_LLAMA_API_KEY=your_nvidia_llama_key_here

# NVIDIA DeepSeek V4 Pro (copilot fallback when Groq is offline)
# Requires NVIDIA NIM access with DeepSeek V4 Pro deployed
NVIDIA_DEEPSEEK_API_KEY=your_deepseek_key_here
